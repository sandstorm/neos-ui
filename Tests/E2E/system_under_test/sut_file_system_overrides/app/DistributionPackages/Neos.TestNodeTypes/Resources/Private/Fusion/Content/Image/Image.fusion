prototype(Neos.TestNodeTypes:Content.Image) < prototype(Neos.Neos:ContentComponent) {
    alternativeText = ${node.properties.alternativeText}
    src = Neos.Neos:ImageUri {
        @if.set = ${this.asset}
        asset = ${node.properties.image}
    }

    renderer = afx`
        <img class="test-image" src={props.src} alt={props.alternativeText} />
    `
}
